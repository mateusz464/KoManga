# KoManga — Compose-level secrets (root docker-compose.yml).
#
# Copy to `.env` (same directory as docker-compose.yml) and fill in. Compose
# reads this file automatically. These are the secrets the orchestration needs;
# the API's own config is documented separately in api/.env.example. Secrets are
# never committed — `.env` is git-ignored.

# Single-user credential required on every /api/* route. Passed into the `api`
# container as AUTH_TOKEN. Compose fails fast if unset.
AUTH_TOKEN=change-me

# Cloudflare Tunnel connector token, from the Cloudflare Zero Trust dashboard
# (Networks → Tunnels → create a tunnel → "Install connector" → copy the token,
# the long string after `--token`). Passed into the `cloudflared` container as
# TUNNEL_TOKEN. Only needed for the `tunnel` profile (`docker compose --profile
# tunnel up -d`); leave blank for LAN-only use. See docs/cloudflare-tunnel.md.
CLOUDFLARE_TUNNEL_TOKEN=
