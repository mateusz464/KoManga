# KoManga API — environment configuration.


# --- Required ---------------------------------------------------------------

# Root URL of the internal Suwayomi server
SUWAYOMI_URL=http://suwayomi:4567

# Single-user credential/token required on every /api/* route.
AUTH_TOKEN=change-me

# AniList OAuth application credentials.
ANILIST_CLIENT_ID=change-me
ANILIST_CLIENT_SECRET=change-me
ANILIST_REDIRECT_URI=https://komanga.example.test/api/tracker/anilist/callback

# --- Optional (defaults shown) ----------------------------------------------
PORT=3000

# Ephemeral session cache bounds. Keyed by page id + profile; pruned by size+TTL.
CACHE_MAX_BYTES=268435456
CACHE_TTL_SECONDS=3600

# Number of pages to prefetch ahead of the requested page.
PREFETCH_WINDOW=3

# Max pages fetched + processed concurrently while building a chapter's CBZ
CBZ_PAGE_CONCURRENCY=6

# Interval, in seconds, for the periodic background refresh of followed manga's
# chapter lists
LIBRARY_REFRESH_INTERVAL_SECONDS=86400

# Per-client rate limit on /api/* routes
RATE_LIMIT=100
RATE_LIMIT_WINDOW_MS=60000

# Target Kobo panel resolution for the `eink` image profile, in pixels.
# Configurable per device model.
IMAGE_TARGET_WIDTH=1072
IMAGE_TARGET_HEIGHT=1448

# Output format for the `eink` profile: one of png, jpeg.
IMAGE_EINK_FORMAT=png

# Log level for the structured JSON logger (pino → stdout)
LOG_LEVEL=info

# Filesystem path to the SQLite database file.
DATABASE_PATH=./data/komanga.sqlite

# Filesystem path to the persistent CBZ download store (separate from cache).
CBZ_STORE_PATH=./data/downloads
