# KoManga API — environment configuration (CLAUDE.md §5).
#
# Copy to `.env` and fill in. All config is read ONLY by src/config; never read
# process.env elsewhere. Required values have no default — startup fails fast
# with a descriptive error if any are missing. Secrets are never committed.

# --- Required ---------------------------------------------------------------

# Root URL of the internal Suwayomi server (no path — the GraphQL endpoint
# `/api/graphql` is appended by the adapter). Reachable only on the internal
# Docker network — never exposed publicly.
SUWAYOMI_URL=http://suwayomi:4567

# Single-user credential/token required on every /api/* route. Secret: keep out
# of version control; never logged.
AUTH_TOKEN=change-me

# --- Optional (defaults shown) ----------------------------------------------

# HTTP port the API listens on.
PORT=3000

# Ephemeral session cache bounds. Keyed by page id + profile; pruned by size+TTL.
CACHE_MAX_BYTES=268435456
CACHE_TTL_SECONDS=3600

# Number of pages to prefetch ahead of the requested page.
PREFETCH_WINDOW=3

# Max pages fetched + processed concurrently while building a chapter's CBZ (the
# transient reader path and explicit downloads). Higher = faster cold reads;
# bounded so a build never opens unlimited connections to Suwayomi/origin.
CBZ_PAGE_CONCURRENCY=6

# Interval, in seconds, for the periodic background refresh of followed manga's
# chapter lists (API-914) — keeps the library's continue/caught-up state current
# by scraping each followed manga's source. Default once a day. Set to 0 to
# disable the background pass entirely.
LIBRARY_REFRESH_INTERVAL_SECONDS=86400

# Per-client rate limit on /api/* routes: max requests per window, and the
# window length in milliseconds. Over the limit within a window → 429.
RATE_LIMIT=100
RATE_LIMIT_WINDOW_MS=60000

# Target Kobo panel resolution for the `eink` image profile, in pixels.
# Configurable per device model.
IMAGE_TARGET_WIDTH=1072
IMAGE_TARGET_HEIGHT=1448

# Output format for the `eink` profile: one of png, jpeg.
IMAGE_EINK_FORMAT=png

# Log level for the structured JSON logger (pino → stdout). One of
# trace, debug, info, warn, error, fatal, silent. The auth token is always
# redacted from log output regardless of level.
LOG_LEVEL=info

# Filesystem path to the SQLite database file.
DATABASE_PATH=./data/komanga.sqlite

# Filesystem path to the persistent CBZ download store (separate from cache).
CBZ_STORE_PATH=./data/downloads

# Path to the built Kobo web client (web-client/dist), served same-origin so the
# client can call /api/* without CORS (KWC-202). Unset = no static client served
# (only /health and /api/*). In dev from the api/ dir this is ../web-client/dist.
CLIENT_DIST_PATH=../web-client/dist
